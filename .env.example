# Configurazione Supabase per GardenOS (Vite)
# Copia come .env e compila i valori. Non committare .env.
#
# Prefissi supportati (Vite è configurato con envPrefix VITE_ + NEXT_PUBLIC_):
#   - VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY  (consigliato per Vite)
#   - NEXT_PUBLIC_SUPABASE_URL + anon o publishable (copia-incolla da altri template)

# URL progetto — Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Chiave pubblica: anon JWT (eyJ...) oppure publishable (sb_publishable_...)
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Connection String PostgreSQL (opzionale, solo per migrazioni/script)
# Sostituisci [YOUR-PASSWORD] con la password del database
# La trovi su: https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/database
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# --- Condomini (ruoli / RLS) ---
# Esegui in ordine: supabase-schema.sql, poi supabase-condomini.sql (SQL Editor).
# Errore 404 su .../rest/v1/profiles → tabella assente: esegui supabase-condomini.sql.
# Imposta app_settings.gestore_user_id = UUID del gestore (stesso user_id di lavori/spese).
# Crea la riga profiles per il gestore (admin, approved) se l’account esisteva già prima del trigger.
# Non servono variabili VITE_ per il gestore: l’UUID è solo in app_settings.
# VITE_ADMIN_EMAIL / VITE_ADMIN_PASSWORD: non più usati dal login (accesso per ruolo da tabella profiles).
